# Terraform working directories
.terraform/
**/.terraform/

# Terraform state and lock files
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Terraform plan output artifacts
*tfplan*
*.tfplan
plan.out

# Crash logs
crash.log
crash.*.log

# Environment-specific variable files (often contain secrets)
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
!*.tfvars.example
!*.auto.tfvars.example

# Generated local backend and vars files in env directories
**/backend.hcl
**/terraform.tfvars
!**/backend.hcl.example

# Credentials & keys
*.pem
*.key
*.p12
service-account*.json

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc
